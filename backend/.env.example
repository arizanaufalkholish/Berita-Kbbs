# ============================================
# BACKEND ENVIRONMENT VARIABLES EXAMPLE
# ============================================
# Salin file ini menjadi .env di direktori backend dan sesuaikan
# dengan konfigurasi server/database Anda. Tanpa file .env yang valid
# aplikasi backend tidak akan berjalan.
#
# Database credentials
DB_HOST=127.0.0.1
DB_NAME=hulusungai_news
DB_USER=hsnews_user
DB_PASS=strongpassword

# Secret key digunakan untuk CSRF, JWT dan keamanan lainnya.
# Gunakan string acak minimal 32 karakter.
API_SECRET_KEY=change_this_secret_key

# Environment (production|development)
APP_ENV=production

# FRONTEND_URL digunakan untuk CORS dan validasi CSRF.
# Jika frontend berada di domain yang sama, Anda dapat membiarkannya kosong.
# Contoh: https://example.com
FRONTEND_URL=

# Optional: Anda dapat menambahkan konfigurasi tambahan seperti SMTP,
# login rate limits, dsb di sini.
