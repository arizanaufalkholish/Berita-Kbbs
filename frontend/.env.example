# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Copy file ini menjadi .env dan isi sesuai environment Anda.
#
# Untuk development lokal:
#   VITE_API_URL=http://localhost:8000/api
#
# Untuk production (ganti dengan domain Anda):
#   VITE_API_URL=https://yourdomain.com/api
#
# PENTING UNTUK HOSTING SHARED / VPS:
# Jika frontend dan backend di-deploy di domain yang sama (misal frontend di root dan backend di folder /api),
# Anda TIDAK PERLU mengisi VITE_API_URL. Biarkan kosong agar otomatis menggunakan /api.

# ============================================
# Opsional: BASE PATH
#
# Secara default, Vite akan membangun aplikasi dengan base path '/'.
# Jika Anda meng-host aplikasi dalam subfolder (mis. example.com/artikel-hulusungai/),
# gunakan VITE_BASE_PATH untuk menentukan subfolder tersebut. Contoh:
#   VITE_BASE_PATH=/artikel-hulusungai/
# Jika kosong, defaultnya adalah '/'. Pastikan nilai diawali dan diakhiri dengan '/'.
# ============================================

# VITE_BASE_PATH=/artikel-hulusungai/
# ============================================

VITE_API_URL=
